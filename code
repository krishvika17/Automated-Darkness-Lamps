const int LEDPin = 9;   // PWM pin 
const int LDRPin = A0;

void setup() {
  Serial.begin(9600);
  pinMode(LEDPin, OUTPUT);
  pinMode(LDRPin, INPUT);
}

void loop() {

  int LDRStatus = analogRead(LDRPin);

  Serial.print("Light Intensity: ");
  Serial.println(LDRStatus);

  if (LDRStatus < 300) {
    analogWrite(LEDPin, 255);   // Very dark → full brightness
    Serial.println("Very Dark → LED Full Bright");
  }

  else if (LDRStatus < 700) {
    analogWrite(LEDPin, 120);   // Medium light → medium brightness
    Serial.println("Medium Light → LED Medium Bright");
  }

  else {
    analogWrite(LEDPin, 0);     // Bright → LED OFF
    Serial.println("Bright → LED OFF");
  }

  delay(500);
}
